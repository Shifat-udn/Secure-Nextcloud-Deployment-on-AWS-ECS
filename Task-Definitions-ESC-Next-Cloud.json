                "command": [
                    "CMD-SHELL",
                    "mysql -u nextcloud -pmaria-pass-XXXXXXXXXXXX -h 127.0.0.1 -e 'SELECT 1;' || exit 1"
                ],
                "interval": 30,
                "timeout": 5,
                "retries": 5,
                "startPeriod": 60
            },
            "systemControls": []
        },
        {
