                    "hostPort": 80,
                    "protocol": "tcp",
                    "name": "http",
                    "appProtocol": "http"
                }
            ],
            "essential": true,
            "environment": [
                {
                    "name": "MYSQL_DATABASE",
                    "value": "nextcloud"
                },
                {
                    "name": "MYSQL_PASSWORD",
                    "value": "maria-pass-XXXXXXXXXXXX"
                },
                {
                    "name": "OVERWRITECLIURL",
                    "value": "https://test.vision.ztrafrica.com"
                },
                {
                    "name": "MYSQL_USER",
                    "value": "nextcloud"
                },
                {
