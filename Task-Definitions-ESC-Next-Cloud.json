                    "value": "10.111.0.0/16"
                },
                {
                    "name": "MYSQL_HOST",
                    "value": "127.0.0.1"
                }
            ],
            "mountPoints": [
                {
                    "sourceVolume": "nextcloud-storage-2",
                    "containerPath": "/var/www/html/data",
                    "readOnly": false
                },
                {
                    "sourceVolume": "nextcloud-config",
                    "containerPath": "/var/www/html/config",
                    "readOnly": false
