                    "value": "test.vision.ztrafrica.com"
                },
                {
                    "name": "NEXTCLOUD_ADMIN_PASSWORD",
                    "value": "ADMINPASS-XXXXXXXXXXXX"
                },
                {
                    "name": "NEXTCLOUD_ADMIN_USER",
                    "value": "admin"
                },
                {
                    "name": "NEXTCLOUD_TRUSTED_DOMAINS",
                    "value": "test.vision.ztrafrica.com nginx-app-928539376.us-east-1.elb.amazonaws.com"
