{
    "taskDefinitionArn": "arn:aws:ecs:us-east-1:XXXXXXXXXXXX:task-definition/ESC-Next-Cloud:10",
    "containerDefinitions": [
        {
            "name": "nextcloud-db",
            "image": "mariadb:10.6",
            "cpu": 0,
            "portMappings": [
                {
                    "containerPort": 3306,
                    "hostPort": 3306,
                    "protocol": "tcp",
                    "name": "db-port"
                }
            ],
            "essential": true,
            "environment": [
                {
                    "name": "MARIADB_DATABASE",
                    "value": "nextcloud"
                },
                {
                    "name": "MARIADB_PASSWORD",
                    "value": "maria-pass-XXXXXXXXXXXX"
                },
                {
                    "name": "MARIADB_ROOT_PASSWORD",
                    "value": "Maria-root-XXXXXXXXXXX"
                },
                {
                    "name": "MARIADB_USER",
                    "value": "nextcloud"
                }
            ],
            "mountPoints": [
                {
                    "sourceVolume": "db-storage",
                    "containerPath": "/var/lib/mysql",
                    "readOnly": false
                }
            ],
            "volumesFrom": [],
